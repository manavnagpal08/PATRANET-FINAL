# Ignore Python cache and runtime virtual environments
__pycache__/
*.pyc
.venv/
env/

# Ignore local document processing cache files
storage/uploads/*
storage/outputs/*
storage/images/*
!storage/uploads/.gitkeep
!storage/outputs/.gitkeep
!storage/images/.gitkeep

# Ignore system configuration credentials
serviceAccountKey.json
.streamlit/
.env
